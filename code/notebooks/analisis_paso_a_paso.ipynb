   "source": [
    "## Paso 8: Guardar Todos los Resultados"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Guardar indicadores y resultados\n",
    "forecast_mensuales.to_csv(os.path.join(OUTPUT_MONTHLY_DIR, \"indicador_mensual.csv\"), sep=\";\")\n",
    "forecast_trimestrales.to_csv(os.path.join(OUTPUT_QUARTERLY_DIR, \"indicador_trimestral.csv\"), sep=\";\")\n",
    "indices_trimestrales.to_csv(os.path.join(OUTPUT_QUARTERLY_DIR, \"indices_trimestrales.csv\"), sep=\";\")\n",
    "resultados_mensuales.to_csv(os.path.join(OUTPUT_MONTHLY_DIR, \"indices_mensuales.csv\"), sep=\";\")\n",
    "print(f\"Resultados guardados en {OUTPUT_DIR}\")\n",
    "\n",
    "# Guardar resumen del modelo y R^2\n",
    "output_file_summary = os.path.join(OUTPUT_RESULTS_DIR, \"resultados_estimaciones.txt\")\n",
    "with open(output_file_summary, 'w') as f:\n",
    "    f.write(\"Resultados de las estimaciones\n=============================\n\n")\n",
    "    f.write(res.summary().as_text())\n",
    "    f.write(f\"\nAIC: {res.aic}\n")\n",
    "    f.write(f\"BIC: {res.bic}\n")\n",
    "    rsquared = res.get_coefficients_of_determination(method='individual')\n",
    "    f.write(\"\nCoeficientes de determinación (R^2):\n===================================\n\n")\n",
    "    f.write(rsquared.to_string())\n",
    "print(f\"Resumen del modelo guardado en {output_file_summary}\")\n",
    "\n",
    "# Guardar resultados del 'news'\n",
    "for name, result in news_results.items():\n",
    "    output_file_news = os.path.join(OUTPUT_NOWCASTING_DIR, f'summary_{name}.txt')\n",
    "    with open(output_file_news, 'w', encoding='utf-8') as f:\n",
    "        f.write(result.summary().as_text())\n",
    "print(f\"Sumarios de 'news' guardados en {OUTPUT_NOWCASTING_DIR}\")\n",
    "\n",
    "# Generar y guardar el fichero de impactos\n",
    "df_impactos = generar_excel_impactos(news_results, ficheros)\n",
    "if not df_impactos.empty:\n",
    "    output_file_impactos = os.path.join(OUTPUT_NOWCASTING_DIR, \"impactos.xlsx\")\n",
    "    df_impactos.to_excel(output_file_impactos, index=False, sheet_name='Impactos')\n",
    "    print(f\"Fichero de impactos guardado en {output_file_impactos}\")\n",
    "else:\n",
    "    print(\"No se generó información de impactos.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Paso 9: Visualización de Resultados"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "forecast_mensuales_f = forecast_mensuales.loc['2022-01':]\n",
    "forecast_trimestrales_f = forecast_trimestrales.loc['2022-01':]\n",
    "\n",
    "n_columns_mensual = forecast_mensuales_f.shape[1]\n",
    "palette_mensual = sns.color_palette(\"Blues_r\", n_colors=n_columns_mensual)\n",
    "\n",
    "n_columns_trimestral = forecast_trimestrales_f.shape[1]\n",
    "palette_trimestral = sns.color_palette(\"Blues_r\", n_colors=n_columns_trimestral)\n",
    "\n",
    "sns.set(style=\"white\", context=\"notebook\", font_scale=0.8)\n",
