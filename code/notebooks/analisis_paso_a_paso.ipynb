   "source": [
    "# Análisis DFMQ - Versión Notebook\n",
    "Este notebook replica la lógica de la aplicación de Streamlit para permitir una ejecución paso a paso y la inspección de resultados intermedios."
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Paso 1: Importar Librerías"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "import re\n",
    "from datetime import datetime\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import warnings\n",
    "warnings.filterwarnings(\"ignore\")\n",
    "import statsmodels.api as sm\n",
    "import io\n",
    "import sys\n",
    "from contextlib import redirect_stdout\n",
    "\n",
    "# Asumimos que utils.py está en el directorio correcto\n",
    "# Añadimos el directorio src al path para poder importar utils\n",
    "sys.path.append(os.path.abspath(os.path.join('..', 'src')))\n",
    "from utils import make_all_stationary_m, make_all_stationary_q"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Paso 2: Definir Funciones Auxiliares"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def denton_method(y, x):\n",
    "    \"\"\"\n",
    "    Implementa el método de Denton para mensualizar series trimestrales.\n",
    "    \n",
    "    :param y: Serie trimestral a desagregar\n",
    "    :param x: Serie mensual relacionada (indicador)\n",
    "    :return: Serie mensual desagregada\n",
    "    \"\"\"\n",
    "    assert len(y) * 3 == len(x), \"La longitud de x debe ser 3 veces la longitud de y\"\n",
    "    \n",
    "    n = len(x)\n",
    "    m = len(y)\n",
    "    \n",
    "    C = np.zeros((m, n))\n",
    "    for i in range(m):\n",
    "        C[i, i*3:(i+1)*3] = 1\n",
    "    \n",
    "    D = np.eye(n) - np.eye(n, k=-1)\n",
    "    D = D[1:, :]\n",
    "    \n",
    "    z = np.linalg.inv(C.T @ C + D.T @ D) @ (C.T @ y + D.T @ D @ x)\n",
    "    \n",
    "    return z\n",
    "\n",
    "def generar_excel_impactos(news_results, ficheros):\n",
    "    \"\"\"\n",
    "    Genera un DataFrame con todos los impactos de cada vintage para guardar en Excel.\n",
    "    \n",
    "    Args:\n",
    "        news_results (dict): Diccionario con los resultados de news entre diferentes vintages.\n",
    "        ficheros (list): Lista de fechas de los vintages en orden cronológico.\n",
    "    \n",
    "    Returns:\n",
    "        pd.DataFrame: DataFrame combinado con todos los impactos.\n",
    "    \"\"\"\n",
    "    if not news_results:\n",
    "        return pd.DataFrame()\n",
    "\n",
    "    dfs = []\n",
    "    for i in range(1, len(ficheros)):\n",
    "        vintage = ficheros[i]\n",
    "        prev_vintage = ficheros[i-1]\n",
    "        \n",
    "        if vintage in news_results:\n",
    "            result = news_results[vintage]\n",
    "            key = f\"{prev_vintage} -> {vintage}\"\n",
    "            \n",
    "            impact_df = result.details_by_impact.reset_index()\n",
    "            temp_df = impact_df[['update date', 'updated variable', 'impact']]\n",
    "            temp_df = temp_df.rename(columns={'impact': f'impacto {key}'})\n",
    "            temp_df = temp_df.set_index('updated variable')\n",
    "            dfs.append(temp_df)\n",
    "\n",
    "    if not dfs:\n",
    "        return pd.DataFrame()\n",
    "\n",
    "    df_final = pd.concat(dfs, axis=1)\n",
    "\n",
    "    update_date_cols = [col for col in df_final.columns if 'update date' in str(col).lower()]\n",
    "    if update_date_cols:\n",
    "        df_final['update_date_merged'] = df_final[update_date_cols].bfill(axis=1).iloc[:, 0]\n",
    "        df_final.drop(columns=update_date_cols, inplace=True)\n",
    "        df_final.rename(columns={'update_date_merged': 'update date'}, inplace=True)\n",
    "        \n",
    "        cols = ['update date'] + [col for col in df_final if col != 'update date']\n",
    "        df_final = df_final[cols]\n",
    "\n",
    "    return df_final.reset_index()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Paso 3: Configuración del Análisis\n",
    "Aquí se definen todas las rutas y parámetros que en la app se configuran en el panel lateral."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Directorio raíz del proyecto (ajustar si es necesario)\n",
    "PROJECT_ROOT = os.path.abspath(os.path.join(os.getcwd(), '..', '..'))\n",
    "print(f\"Directorio Raíz: {PROJECT_ROOT}\")\n",
    "\n",
    "# Creación de directorios de salida\n",
    "DATA_DIR = os.path.join(PROJECT_ROOT, 'data')\n",
    "OUTPUT_DIR = os.path.join(PROJECT_ROOT, 'output', 'notebook_outputs') # Usamos un subdirectorio para no mezclar resultados\n",
    "OUTPUT_MONTHLY_DIR = os.path.join(OUTPUT_DIR, 'monthly')\n",
    "OUTPUT_QUARTERLY_DIR = os.path.join(OUTPUT_DIR, 'quarterly')\n",
    "OUTPUT_NOWCASTING_DIR = os.path.join(OUTPUT_DIR, 'nowcasting')\n",
    "OUTPUT_RESULTS_DIR = os.path.join(OUTPUT_DIR, 'results')\n",
    "\n",
    "for directory in [OUTPUT_DIR, OUTPUT_MONTHLY_DIR, OUTPUT_QUARTERLY_DIR, OUTPUT_NOWCASTING_DIR, OUTPUT_RESULTS_DIR]:\n",
    "    os.makedirs(directory, exist_ok=True)\n",
    "\n",
    "# Parámetros del modelo DFMQ\n",
    "factor_orders = 2\n",
    "factors = 1\n",
    "include_dummies = False\n",
    "end_date = '2024-12'\n",
    "\n",
    "# Selección de variables (regresores)\n",
    "mejores_regresores_m = [\n",
    "    'Consumo aparente de cemento - Andalucía', \n",
    "    'Total afiliados SS Total - Andalucía',\n",
    "    'Matriculación de turismos - Andalucía'\n",
    "]\n",
    "mejores_regresores_q = [\n",
    "    'Ocupados EPA  total - Andalucía',\n",
    "    'Índice de producción agrícola - Andalucía',\n",
    "    'pib'\n",
    "]\n",
    "\n",
    "# Nombres de las hojas de Excel\n",
    "nombre_hoja_mensual = 'Series_mens_vol_y_desest'\n",
    "nombre_hoja_trimestre = 'Serie trim_vol_desest_Índice'\n",
    "\n",
    "# Patrón para extraer la fecha del nombre del fichero\n",
    "patron_fecha = 'Envío_(\d{2})_(\d{2})_(\d{4})'"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Paso 4: Carga y Procesamiento de Datos\n",
    "Se buscan los ficheros Excel en el directorio `data`, se leen y se procesan para dejarlos listos para el modelo."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "dfs_m = {}\n",
    "dfs_q = {}\n",
    "\n",
    "# Encontrar todos los ficheros Excel en el directorio de datos\n",
    "uploaded_files = [os.path.join(DATA_DIR, f) for f in os.listdir(DATA_DIR) if f.endswith('.xlsx') and not f.startswith('~$')]\n",
    "\n",
    "for file_path in uploaded_files:\n",
    "    file_name = os.path.basename(file_path)\n",
    "    print(f\"Procesando {file_name}...\")\n",
    "    try:\n",
    "        match = re.search(patron_fecha, file_name)\n",
    "        if match:\n",
    "            dia, mes, anio = match.groups()\n",
    "            fecha = datetime(int(anio), int(mes), int(dia)).strftime('%Y-%m-%d')\n",
    "            \n",
    "            # Leer datos mensuales\n",
    "            df_mens = pd.read_excel(file_path, sheet_name=nombre_hoja_mensual)\n",
    "            df_mens['fecha'] = pd.to_datetime(df_mens['fecha']).dt.strftime('%m-%y')\n",
    "            df_mens.set_index('fecha', inplace=True)\n",
    "            \n",
    "            # Leer datos trimestrales\n",
    "            df_trims = pd.read_excel(file_path, sheet_name=nombre_hoja_trimestre)\n",
    "            df_trims['fecha'] = pd.to_datetime(df_trims['fecha']).dt.strftime('%m-%y')\n",
    "            df_trims.set_index('fecha', inplace=True)\n",
    "            \n",
    "            # Procesar estacionaridad\n",
    "            df_estacionario_mensual, _ = make_all_stationary_m(df_mens)\n",
    "            df_estacionario_trimestral, _ = make_all_stationary_q(df_trims)\n",
    "            \n",
    "            # Procesamiento adicional\n",
    "            df_estacionario_mensual['Total afiliados SS Total - Andalucía'] = df_mens['Total afiliados SS Total - Andalucía'].diff(3)\n",
    "            \n",
    "            endog_m = df_estacionario_mensual\n",
    "            endog_q = df_estacionario_trimestral * 100\n",
    "            \n",
    "            # Convertir índices a PeriodIndex\n",
    "            endog_m.index = pd.to_datetime(endog_m.index, format='%m-%y').to_period('M')\n",
    "            endog_q.index = pd.to_datetime(endog_q.index, format='%m-%y').to_period('Q')\n",
    "            \n",
    "            # Almacenar DataFrames\n",
    "            dfs_m[fecha] = endog_m\n",
    "            dfs_q[fecha] = endog_q\n",
    "            print(f\"  -> Fichero {file_name} procesado correctamente.\")\n",
    "        else:\n",
    "            print(f\"  -> ERROR: No se pudo extraer la fecha del archivo {file_name}\")\n",
    "    except Exception as e:\n",
    "        print(f\"  -> ERROR procesando {file_name}: {str(e)}\")\n",
    "\n",
    "# Ordenar ficheros por fecha\n",
    "ficheros = sorted(list(dfs_m.keys()), key=lambda x: datetime.strptime(x, '%Y-%m-%d'))\n",
    "dfs_m = {fecha: dfs_m[fecha] for fecha in ficheros}\n",
    "dfs_q = {fecha: dfs_q[fecha] for fecha in ficheros}\n",
    "\n",
    "print(f\"\nProcesamiento completado. {len(ficheros)} archivos procesados.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Paso 5: Estimación del Modelo DFMQ\n",
    "Se estima el modelo con el primer vintage de datos."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"Estimando modelo DFMQ...\")\n",
    "\n",
    "# Preparar datos para el modelo con el primer fichero\n",
    "endog_m_c = dfs_m[ficheros[0]][mejores_regresores_m]\n",
    "endog_q = dfs_q[ficheros[0]][mejores_regresores_q]\n",
    "\n",
    "# Añadir dummies si la opción está seleccionada\n",
    "if include_dummies:\n",
    "    print(\"Incluyendo dummies para COVID-19...\")\n",
    "    for q in range(1, 5):\n",
    "        col_name = f'D2020Q{q}'\n",
    "        endog_q[col_name] = 0\n",
    "        if f'2020Q{q}' in endog_q.index.strftime('%YQ%q'):\n",
    "            endog_q.loc[endog_q.index.strftime('%YQ%q') == f'2020Q{q}', col_name] = 1\n",
    "\n",
    "# Crear y ajustar el modelo\n",
    "mod = sm.tsa.DynamicFactorMQ(\n",
    "    endog_m_c,\n",
    "    endog_quarterly=endog_q,\n",
    "    factor_orders=factor_orders,\n",
    "    factors=factors,\n",
    "    factor_multiplicities=None\n",
    "    )\n",
    "\n",
    "res = mod.fit(maxiter=2000)\n",
    "\n",
    "print(\"Modelo estimado correctamente.\")\n",
    "\n",
    "# Mostrar resumen del modelo\n",
    "print(res.summary())"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Paso 6: Generación de Predicciones y Análisis 'News'\n",
    "Se aplica el modelo al resto de vintages y se realiza el análisis de 'news'."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"Generando predicciones y análisis 'news'...\")\n",
    "\n",
    "# Archivo de resultados para cada vintage\n",
    "vintage_results = {ficheros[0]: res}\n",
    "start = '2000'\n",
    "\n",
    "# Aplicar resultados al resto de vintages\n",
    "for vintage in ficheros[1:]:\n",
    "    print(f\"Procesando vintage: {vintage}\")\n",
    "    updated_endog_m = dfs_m[vintage][mejores_regresores_m].loc[start:]\n",
    "    updated_endog_q = dfs_q[vintage][mejores_regresores_q].loc[start:]\n",
    "\n",
    "    if include_dummies:\n",
    "        for q in range(1, 5):\n",
    "            col_name = f'D2020Q{q}'\n",
    "            updated_endog_q[col_name] = 0\n",
    "            if f'2020Q{q}' in updated_endog_q.index.strftime('%YQ%q'):\n",
    "                updated_endog_q.loc[updated_endog_q.index.strftime('%YQ%q') == f'2020Q{q}', col_name] = 1\n",
    "    \n",
    "    vintage_results[vintage] = res.apply(\n",
    "        updated_endog_m, endog_quarterly=updated_endog_q, retain_standardization=False\n",
    "    )\n",
    "\n",
    "# Calcular resultados de 'news'\n",
    "news_results = {}\n",
    "impact_date = end_date\n",
    "\n",
    "for i in range(1, len(ficheros)):\n",
    "    vintage = ficheros[i]\n",
    "    prev_vintage = ficheros[i - 1]\n",
    "    print(f\"Calculando 'news' entre {prev_vintage} y {vintage}...\")\n",
    "    news_results[vintage] = vintage_results[vintage].news(\n",
    "        vintage_results[prev_vintage],\n",
    "        impact_date=impact_date,\n",
    "        impacted_variable='pib',\n",
    "        comparison_type='previous'\n",
    "    )\n",
    "\n",
    "print(\"Análisis 'news' completado.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Paso 7: Cálculo de Índices y Resultados Finales"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Calcular predicciones para cada vintage\n",
    "forecasts_m = {vintage: res.get_prediction(start='2006-01', end=end_date).predicted_mean['pib'] for vintage, res in vintage_results.items()}\n",
    "forecast_mensuales = pd.DataFrame(forecasts_m)\n",
    "\n",
    "forecasts_q = {vintage: res.get_prediction(start='2006-01', end=end_date).predicted_mean['pib'].resample('Q').first() for vintage, res in vintage_results.items()}\n",
    "forecast_trimestrales = pd.DataFrame(forecasts_q)\n",
    "\n",
    "# Convertir índices a DatetimeIndex\n",
    "forecast_mensuales.index = forecast_mensuales.index.to_timestamp()\n",
    "forecast_trimestrales.index = forecast_trimestrales.index.to_timestamp()\n",
    "\n",
    "# Crear índices trimestrales base 100\n",
    "indices_trimestrales = pd.DataFrame(index=forecast_trimestrales.index)\n",
    "for columna in forecast_trimestrales.columns:\n",
    "    serie_indice = pd.Series(index=forecast_trimestrales.index, dtype=float)\n",
    "    serie_indice.iloc[0] = 100\n",
    "    for i in range(1, len(serie_indice)):\n",
    "        tasa_crecimiento = forecast_trimestrales[columna].iloc[i]\n",
    "        serie_indice.iloc[i] = serie_indice.iloc[i-1] * (1 + tasa_crecimiento/100)\n",
    "    indices_trimestrales[columna] = serie_indice\n",
    "\n",
    "# Mensualizar índices trimestrales usando el método de Denton\n",
    "df_mens_moving_average = forecast_mensuales.rolling(window=3, min_periods=1).mean()\n",
    "df_mensualizada = 100*((1 + df_mens_moving_average/100) ** (1/3)-1)\n",
    "df_growth_based = pd.DataFrame(index=df_mensualizada.index, columns=df_mensualizada.columns)\n",
    "df_growth_based.iloc[0] = 100\n",
    "for i in range(1, len(df_mensualizada)):\n",
    "    df_growth_based.iloc[i] = df_growth_based.iloc[i-1] * (1 + df_mensualizada.iloc[i]/100)\n",
    "\n",
    "def safe_convert_to_float(arr):\n",
    "    series = pd.Series(arr)\n",
    "    numeric_series = pd.to_numeric(series, errors='coerce')\n",
    "    cleaned_series = numeric_series.dropna()\n",
    "    return cleaned_series.to_numpy()\n",
    "\n",
    "resultados_mensuales = pd.DataFrame(index=df_growth_based.index)\n",
    "for columna in df_growth_based.columns:\n",
    "    X_mensual = df_growth_based[columna].to_numpy()\n",
    "    if columna in indices_trimestrales.columns:\n",
    "        y_trimestral = indices_trimestrales[columna].to_numpy()\n",
    "    else:\n",
    "        continue\n",
    "    X_mensual_clean = safe_convert_to_float(X_mensual)\n",
    "    y_trimestral_clean = safe_convert_to_float(y_trimestral)\n",
    "    z_mensual = denton_method(y_trimestral_clean, X_mensual_clean) * 3\n",
    "    resultados_mensuales[columna] = pd.Series(z_mensual, index=df_growth_based.index)\n",
    "\n",
    "print(\"Preview de Índices Trimestrales:\")\n",
    "display(indices_trimestrales.tail())\n",
    "print(\"\nPreview de Índices Mensuales:\")\n",
    "display(resultados_mensuales.tail())"
   ]
  },
  {
